# ============ MODEL 1: NEURAL COLLABORATIVE FILTERING (Functional API) ============
if TF_AVAILABLE:
    print("[1/4] Building Neural Collaborative Filtering Model...")
    # Input layers
    user_input = layers.Input(shape=(1,), name='user_input')
    movie_input = layers.Input(shape=(1,), name='movie_input')
    # Embedding layers
    user_embedding = layers.Embedding(num_users, 50, name='user_embedding')(user_input)
    user_vec = layers.Flatten()(user_embedding)
    movie_embedding = layers.Embedding(num_movies, 50, name='movie_embedding')(movie_input)
    movie_vec = layers.Flatten()(movie_embedding)
    # Concatenate
    concat = layers.Concatenate()([user_vec, movie_vec])
    # Deep layers
    dense1 = layers.Dense(128, activation='relu')(concat)
    dropout1 = layers.Dropout(0.3)(dense1)
    dense2 = layers.Dense(64, activation='relu')(dropout1)
    dropout2 = layers.Dropout(0.3)(dense2)
    dense3 = layers.Dense(32, activation='relu')(dropout2)
    output = layers.Dense(1)(dense3)
    # Build model
    ncf_model = Model(inputs=[user_input, movie_input], outputs=output, name='NCF')
    ncf_model.compile(optimizer='adam', loss='mse', metrics=['mae'])
    print("Training NCF Model (20 epochs)...")
    history = ncf_model.fit(
        [X_train[:, 0], X_train[:, 1]], y_train,
        batch_size=64, epochs=20, verbose=0,
        validation_split=0.1,
        callbacks=[keras.callbacks.EarlyStopping(patience=5, restore_best_weights=True)]
    )
    test_loss, test_mae = ncf_model.evaluate([X_test[:, 0], X_test[:, 1]], y_test, verbose=0)
    print(f"✓ NCF Model - Test MAE: {test_mae:.4f}, Test Loss: {test_loss:.4f}")
