# ============ MODEL 4: HYBRID RECOMMENDER ============
print("\n[4/4] Building Hybrid Recommendation Engine...")
class HybridRecommender:
    def __init__(self, ncf_model, movie_similarity, svd_predictions, movies_df, ratings_df):
        self.ncf_model = ncf_model
        self.movie_similarity = movie_similarity
        self.svd_predictions = svd_predictions
        self.movies_df = movies_df
        self.ratings_df = ratings_df
    def get_recommendations(self, user_id, top_n=10, method='hybrid', preferred_genres=None):
        """Get movie recommendations using hybrid approach"""
        rated_movies = self.ratings_df[self.ratings_df['user_id'] == user_id]['movie_id'].values
        all_movies = self.movies_df['movie_id'].values
        unseen_movies = [m for m in all_movies if m not in rated_movies]
        if len(unseen_movies) == 0:
            return pd.DataFrame()
        recommendations = []
        for movie_id in unseen_movies:
            if preferred_genres:
                movie_genres = set(self.movies_df.iloc[movie_id]['genres'])
                if not movie_genres.intersection(set(preferred_genres)):
                    continue
            # 1. Neural CF Score (40% weight)
            ncf_pred = self.ncf_model.predict([np.array([user_id]), np.array([movie_id])], verbose=0)
            ncf_score = float(np.array(ncf_pred).flatten()[0])
            # 2. Content-Based Score (30% weight)
            content_score = 0.0
            if len(rated_movies) > 0:
                similarities = self.movie_similarity[movie_id][rated_movies]
                content_score = float(np.mean(similarities))
            # 3. SVD Score (30% weight)
            svd_score = float(self.svd_predictions.iloc[user_id, movie_id])
            # Hybrid score
            if method == 'hybrid':
                final_score = 0.4 * ncf_score + 0.3 * content_score * 10 + 0.3 * svd_score
            elif method == 'neural':
                final_score = ncf_score
            elif method == 'content':
                final_score = content_score * 10
            else:
                final_score = svd_score

            # Add diversity bonus for less popular movies
            popularity = len(self.ratings_df[self.ratings_df['movie_id'] == movie_id])
            diversity_bonus = 1 / (1 + np.log1p(popularity))
            final_score += 0.1 * diversity_bonus
            recommendations.append({
                'movie_id': movie_id,
                'title': self.movies_df.iloc[movie_id]['title'],
                'genres': self.movies_df.iloc[movie_id]['genres'],
                'score': final_score,
                'ncf_score': ncf_score,
                'content_score': content_score,
                'svd_score': svd_score,
                'popularity': popularity
            })
        # Sort by score and return top N
        recommendations_df = pd.DataFrame(recommendations)
        if len(recommendations_df) > 0:
            recommendations_df = recommendations_df.sort_values('score', ascending=False).head(top_n)
        return recommendations_df

    def explain_recommendation(self, user_id, movie_id):
        """Explain why a movie was recommended"""
        movie_title = self.movies_df.iloc[movie_id]['title']
        movie_genres = self.movies_df.iloc[movie_id]['genres']
        # Find similar movies user has rated
        rated_movies = self.ratings_df[self.ratings_df['user_id'] == user_id]
        similar_rated = []

        for _, rating in rated_movies.iterrows():
            mid = int(rating['movie_id'])
            sim = self.movie_similarity[movie_id][mid]
            if sim > 0.3:
                similar_rated.append({
                    'title': self.movies_df.iloc[mid]['title'],
                    'similarity': sim,
                    'your_rating': rating['rating']
                })

        explanation = f"\nWhy we recommend '{movie_title}':\n"
        explanation += f"  - Genres: {', '.join(movie_genres)}\n"
        if similar_rated:
            explanation += f"  - Similar to movies you enjoyed:\n"
            for item in sorted(similar_rated, key=lambda x: x['similarity'], reverse=True)[:3]:
                explanation += f"    * {item['title']} (similarity: {item['similarity']:.2f}, you rated: {item['your_rating']:.1f})\n"

        return explanation

